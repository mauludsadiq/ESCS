import("std/crypto") as crypto
import("std/hash") as hash
import("std/str") as str
import("std/json") as json

// keypair.fard — Ed25519 key generation and signing
// Mirrors Anka's keypair.fard exactly for interop.

fn strip_prefix(hex_with_prefix) {
  str.slice(hex_with_prefix, 7, str.len(hex_with_prefix))
}

fn generate(seed) {
  let raw = hash.sha256_text(seed) in
  let private_key_hex = strip_prefix(raw) in
  let public_key_hex = crypto.ed25519_public_key(private_key_hex) in
  {
    private_key_hex: private_key_hex,
    public_key_hex: public_key_hex,
    node_id: str.concat(["ed25519:", public_key_hex])
  }
}

fn sign(private_key_hex, message_hex) {
  crypto.ed25519_sign(private_key_hex, message_hex)
}

fn verify(public_key_hex, message_hex, signature_hex) {
  crypto.ed25519_verify(public_key_hex, message_hex, signature_hex)
}

fn node_id_from_public_key(public_key_hex) {
  str.concat(["ed25519:", public_key_hex])
}

fn public_key_from_node_id(node_id) {
  str.slice(node_id, 8, str.len(node_id))
}

export { strip_prefix, generate, sign, verify, node_id_from_public_key, public_key_from_node_id }
