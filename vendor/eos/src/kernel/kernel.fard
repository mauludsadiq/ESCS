import("k1") as k1
import("claim") as claim
import("gate") as gate
import("witness") as witness
import("gossip") as gossip
import("keypair") as keypair
import("challenge") as challenge

// kernel.fard — assembles all seven primitives into one record

fn new(node_seed) {
  let kp = keypair.generate(node_seed) in
  {
    keypair: kp,
    k1: k1.new(),
    gossip: gossip.new()
  }
}

fn write_blob(k, data) {
  let r = k1.write(k.k1, data) in
  { kernel: {...k, k1: r.store}, digest: r.digest }
}

fn read_blob(k, digest_hex) {
  k1.read(k.k1, digest_hex)
}

fn mint_claim(k, claim_space, subject, predicate, object, evidence_refs, timestamp_unix_secs) {
  claim.sign(
    claim.make(claim_space, subject, predicate, object, evidence_refs, k.keypair.node_id, timestamp_unix_secs),
    k.keypair.private_key_hex
  )
}

fn verify_claim(k, envelope, public_key_hex) {
  claim.verify(envelope, public_key_hex)
}

fn eval_gate(claim_obj, ctx_json) {
  gate.eval_with_ctx_json(claim_obj, ctx_json)
}

fn build_witness(k, subject, claim_envelopes, timestamp_unix_secs) {
  witness.make(subject, claim_envelopes, k.keypair.private_key_hex, timestamp_unix_secs)
}

fn pub_gossip(k, topic, msg) {
  let g2 = gossip.publish(k.gossip, topic, msg) in
  {...k, gossip: g2}
}

fn sub_gossip(k, topic) {
  let r = gossip.subscribe(k.gossip, topic) in
  { kernel: {...k, gossip: r.store}, msgs: r.msgs }
}

// Challenge: proof of possession
fn issue_challenge(k, target_node_id, timestamp_unix_secs) {
  challenge.make_nonce(k.keypair.node_id, target_node_id, timestamp_unix_secs)
}

fn respond_to_challenge(k, nonce) {
  challenge.respond(nonce, k.keypair.private_key_hex)
}

fn verify_challenge_response(nonce, response, target_public_key_hex) {
  challenge.verify_response(nonce, response, target_public_key_hex)
}

// Challenge: contest a claim
fn contest_claim(k, target_digest_hex, kind, evidence, timestamp_unix_secs) {
  challenge.make_claim_challenge(
    target_digest_hex, k.keypair.node_id, kind, evidence,
    timestamp_unix_secs, k.keypair.private_key_hex
  )
}

fn verify_contest(c, challenger_public_key_hex) {
  challenge.verify_claim_challenge(c, challenger_public_key_hex)
}

export {
  new, write_blob, read_blob, mint_claim, verify_claim, eval_gate,
  build_witness, pub_gossip, sub_gossip,
  issue_challenge, respond_to_challenge, verify_challenge_response,
  contest_claim, verify_contest
}
