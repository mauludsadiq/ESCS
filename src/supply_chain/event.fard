import("std/json") as json
import("std/str") as str
import("std/rec") as rec
import("std/list") as list
import("std/type") as type
import("./jurisdictions") as jur

// event.fard — all ESCS supply chain event types
//
// Every supply chain action is a typed, validated event record.
// Events are signed by the EOS kernel and published as claims.
//
// Event kinds:
//   Batch lifecycle:    batch_created, batch_split, batch_merge
//   Custody:            custody_transfer
//   Inspection:         inspection_passed, inspection_failed
//   Customs:            customs_cleared, customs_held
//   Cold chain:         temperature_log, temperature_breach
//   Certification:      certification_issued, certification_revoked
//   Recall:             recall_issued, recall_acknowledged, recall_resolved
//   Sensor:             sensor_reading
//   Location:           location_update
//   Origin:             origin_attested

// --- Batch lifecycle ---

fn batch_created(batch_id, product_code, quantity, unit, origin_location,
                producer_id, lot_number, manufacture_date, expiry_date) {
 {
   kind:             "batch_created",
   batch_id:         batch_id,
   product_code:     product_code,
   quantity:         quantity,
   unit:             unit,
   origin_location:  origin_location,
   producer_id:      producer_id,
   lot_number:       lot_number,
   manufacture_date: manufacture_date,
   expiry_date:      expiry_date
 }
}

fn batch_split(parent_batch_id, child_batch_ids, quantities, actor_id) {
 {
   kind:             "batch_split",
   parent_batch_id:  parent_batch_id,
   child_batch_ids:  child_batch_ids,
   quantities:       quantities,
   actor_id:         actor_id
 }
}

fn batch_merge(source_batch_ids, target_batch_id, quantities, actor_id) {
 {
   kind:             "batch_merge",
   source_batch_ids: source_batch_ids,
   target_batch_id:  target_batch_id,
   quantities:       quantities,
   actor_id:         actor_id
 }
}

// --- Custody ---

fn custody_transfer(batch_id, from_party, to_party, location,
                   quantity, unit, handoff_method, actor_id) {
 {
   kind:           "custody_transfer",
   batch_id:       batch_id,
   from_party:     from_party,
   to_party:       to_party,
   location:       location,
   quantity:       quantity,
   unit:           unit,
   handoff_method: handoff_method,
   actor_id:       actor_id
 }
}

