// --- Cold chain ---

fn temperature_log(batch_id, sensor_id, location,
                  temp_min_c, temp_max_c, temp_avg_c,
                  window_start, window_end, reading_count) {
 {
   kind:          "temperature_log",
   batch_id:      batch_id,
   sensor_id:     sensor_id,
   location:      location,
   temp_min_c:    temp_min_c,
   temp_max_c:    temp_max_c,
   temp_avg_c:    temp_avg_c,
   window_start:  window_start,
   window_end:    window_end,
   reading_count: reading_count
 }
}

fn temperature_breach(batch_id, sensor_id, location,
