   standards:         standards,
   evidence_refs:     evidence_refs
 }
}

// --- Helpers ---

fn event_kind(event) { event.kind }
fn event_batch_id(event) { rec.getOr(event, "batch_id", null) }

fn is_recall_event(event) {
 let k = event.kind in
 k == "recall_issued" || k == "recall_acknowledged" || k == "recall_resolved"
}

fn is_cold_chain_event(event) {
 let k = event.kind in
 k == "temperature_log" || k == "temperature_breach"
}

fn is_custody_event(event) {
 let k = event.kind in
 k == "custody_transfer" || k == "batch_created" ||
 k == "batch_split" || k == "batch_merge"
}

fn is_inspection_event(event) {
 let k = event.kind in
 k == "inspection_passed" || k == "inspection_failed"
}

fn is_customs_event(event) {
 let k = event.kind in
 k == "customs_cleared" || k == "customs_held"
}

fn is_certification_event(event) {
 let k = event.kind in
 k == "certification_issued" || k == "certification_revoked"
}

fn claim_space_for(event) {
 match event.kind {
   "batch_created"          => jur.SUPPLY_BATCH_V1,
   "batch_split"            => jur.SUPPLY_BATCH_V1,
   "batch_merge"            => jur.SUPPLY_BATCH_V1,
   "custody_transfer"       => jur.SUPPLY_CUSTODY_V1,
   "inspection_passed"      => jur.SUPPLY_INSPECTION_V1,
   "inspection_failed"      => jur.SUPPLY_INSPECTION_V1,
   "customs_cleared"        => jur.SUPPLY_CUSTOMS_US_V1,
   "customs_held"           => jur.SUPPLY_CUSTOMS_US_V1,
   "temperature_log"        => jur.SUPPLY_SENSOR_V1,
   "temperature_breach"     => jur.SUPPLY_SENSOR_V1,
   "certification_issued"   => jur.SUPPLY_ISO9001_V1,
   "certification_revoked"  => jur.SUPPLY_ISO9001_V1,
   "recall_issued"          => jur.SUPPLY_RECALL_V1,
   "recall_acknowledged"    => jur.SUPPLY_RECALL_V1,
   "recall_resolved"        => jur.SUPPLY_RECALL_V1,
   "sensor_reading"         => jur.SUPPLY_SENSOR_V1,
   "location_update"        => jur.SUPPLY_STATE_V1,
   "origin_attested"        => jur.SUPPLY_ORACLE_V1,
   _                        => jur.SUPPLY_STATE_V1
 }
}

fn subject_for(event) {
 let batch = rec.getOr(event, "batch_id", "unknown") in
 str.concat(["sc:", event.kind, ":", batch])
}

fn severity_level(severity) {
 match severity {
   "class_i"   => 3,
   "class_ii"  => 2,
   "class_iii" => 1,
   _           => 0
 }
}

fn is_critical_recall(event) {
 event.kind == "recall_issued" && severity_level(rec.getOr(event, "severity", "")) >= 3
}

let ALL_KINDS = [
 "batch_created", "batch_split", "batch_merge",
 "custody_transfer",
 "inspection_passed", "inspection_failed",
 "customs_cleared", "customs_held",
 "temperature_log", "temperature_breach",
 "certification_issued", "certification_revoked",
 "recall_issued", "recall_acknowledged", "recall_resolved",
 "sensor_reading", "location_update", "origin_attested"
]

fn is_known_kind(kind) {
 list.any(ALL_KINDS, fn(k) { k == kind })
}

export {
 batch_created, batch_split, batch_merge,
 custody_transfer,
 inspection_passed, inspection_failed,
 customs_cleared, customs_held,
 temperature_log, temperature_breach,
 certification_issued, certification_revoked,
 recall_issued, recall_acknowledged, recall_resolved,
 sensor_reading, location_update, origin_attested,
 event_kind, event_batch_id,
 is_recall_event, is_cold_chain_event, is_custody_event,
 is_inspection_event, is_customs_event, is_certification_event,
 claim_space_for, subject_for, severity_level, is_critical_recall,
 ALL_KINDS, is_known_kind
}
