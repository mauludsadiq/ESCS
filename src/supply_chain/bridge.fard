// bridge.fard — full ESCS pipeline
//
// Every supply chain event flows through this pipeline:
//
//   1. event arrives (any of 18 types)
//   2. convert to eOS claim envelope (sc_claim.event_to_envelope)
//   3. evaluate against jurisdiction gate policy
//   4. if gate passes: publish to Anka mesh
//   5. submit structural witness for published claim
//   6. return full result record
//
// Special pipelines:
//   publish_sensor_window  — aggregated IoT window claim
//   publish_breach         — immediate, bypasses windowing
//   publish_recall         — high-stakes, notifies all subscribers
//   publish_silence        — non-compliance record
//   publish_batch          — full batch lifecycle event set
//
// Result record:
//   { envelope, gate_result, anka_result, witness_result,
//     published, witnessed, claim_space, digest_hex }

// --- Anka client ---

fn make_client(anka_url) {
 anka.client(anka_url)
}

// --- Core pipeline ---

fn publish_event(anka_client, k, event, timestamp_unix_secs, reputation) {
 let envelope = sc_claim.event_to_envelope(k, event, timestamp_unix_secs) in
 let claim_space = envelope.claim.claim_space in
 let p = policy.policy_for(claim_space) in
 let ctx = { reputation: reputation, now: timestamp_unix_secs, policy: p } in
 let gate_result = eos.eval_gate(envelope.claim, ctx) in
 let published = rec.has(gate_result, "ok") in
 let anka_result = if published
   then anka.publish_envelope(anka_client, envelope)
   else { ok: false, reason: "gate denied", gate: gate_result } in
 let actually_published = published && rec.getOr(anka_result, "ok", false) in
 let witness_result = if actually_published
   then witness_bridge.submit_structural(
     anka_client, k, envelope.digest_hex, timestamp_unix_secs)
   else { ok: false, reason: "skipped — not published" } in
 {
   envelope:       envelope,
   gate_result:    gate_result,
   anka_result:    anka_result,
   witness_result: witness_result,
   published:      actually_published,
   witnessed:      actually_published && rec.getOr(witness_result, "ok", false),
   claim_space:    claim_space,
   digest_hex:     envelope.digest_hex
 }
}

// --- Typed pipeline functions ---

fn publish_batch_created(anka_client, k, event, timestamp_unix_secs) {
 publish_event(anka_client, k, event, timestamp_unix_secs, 0)
}

fn publish_custody_transfer(anka_client, k, event, timestamp_unix_secs) {
 publish_event(anka_client, k, event, timestamp_unix_secs, 0)
}

