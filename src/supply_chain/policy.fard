import("std/list") as list
import("std/rec") as rec
import("./jurisdictions") as jur

// policy.fard — gate policies for all ESCS verticals
//
// Every policy is a GateVM program: a list of ops that evaluates
// a claim against a context { reputation, now, allowed_jurisdictions }.
//
// Policy hierarchy (strictest to most open):
//   recall_policy         RepMin(50) — only highest-rep nodes issue recalls
//   cold_chain_policy     RepMin(10) + AgeMax(3600) — fresh, trusted
//   customs_policy        RepMin(10) + AgeMax(86400)
//   certification_policy  RepMin(20)
//   inspection_policy     RepMin(5)
//   sensor_policy         RepMin(1) + AgeMax(300) — sensor readings stale fast
//   custody_policy        RepMin(0) — any participant
//   open_policy           JurAllow(all) — dev/test only
//
// Per-vertical policies add JurAllow constraints on top of base reputation gates.

// --- Base reputation policies ---

let rep_0  = { rules: [{ op: "RepMin", val: 0  }] }
let rep_1  = { rules: [{ op: "RepMin", val: 1  }] }
let rep_5  = { rules: [{ op: "RepMin", val: 5  }] }
let rep_10 = { rules: [{ op: "RepMin", val: 10 }] }
let rep_20 = { rules: [{ op: "RepMin", val: 20 }] }
let rep_50 = { rules: [{ op: "RepMin", val: 50 }] }

// --- Cross-vertical policies ---

let custody_policy = {
 rules: [
   { op: "JurAllow", list: ["SUPPLY.CUSTODY.v1"] },
   { op: "RepMin", val: 0 },
   { op: "Glb", n: 2 }
 ]
}

let inspection_policy = {
 rules: [
   { op: "JurAllow", list: ["SUPPLY.INSPECTION.v1"] },
   { op: "RepMin", val: 5 },
   { op: "Glb", n: 2 }
 ]
}

let sensor_policy = {
 rules: [
   { op: "JurAllow", list: ["SUPPLY.SENSOR.v1"] },
   { op: "RepMin", val: 1 },
   { op: "AgeMax", seconds: 300 },
   { op: "Glb", n: 3 }
 ]
}

let recall_policy = {
 rules: [
   { op: "JurAllow", list: ["SUPPLY.RECALL.v1", "PHARMA.RECALL.v1", "FOOD.RECALL.v1"] },
   { op: "RepMin", val: 50 },
   { op: "Glb", n: 2 }
 ]
}

