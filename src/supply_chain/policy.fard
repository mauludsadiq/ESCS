// --- Policy router ---
// Returns the correct policy for a given claim space

fn policy_for(claim_space) {
 match claim_space {
   "SUPPLY.CUSTODY.v1"       => custody_policy,
   "SUPPLY.INSPECTION.v1"    => inspection_policy,
   "SUPPLY.SENSOR.v1"        => sensor_policy,
   "SUPPLY.RECALL.v1"        => recall_policy,
   "SUPPLY.ISO9001.v1"       => iso9001_policy,
   "SUPPLY.ISO28000.v1"      => iso28000_policy,
   "SUPPLY.CUSTOMS.US.v1"    => customs_us_policy,
   "SUPPLY.CUSTOMS.EU.v1"    => customs_eu_policy,
   "SUPPLY.CUSTOMS.UK.v1"    => customs_uk_policy,
   "SUPPLY.CUSTOMS.CN.v1"    => customs_cn_policy,
   "SUPPLY.CUSTOMS.JP.v1"    => customs_jp_policy,
   "PHARMA.FDA.DSCSA.v1"     => pharma_fda_dscsa_policy,
   "PHARMA.EMA.FMD.v1"       => pharma_ema_fmd_policy,
   "PHARMA.COLD.FDA.v1"      => pharma_cold_fda_policy,
   "PHARMA.COLD.WHO.v1"      => pharma_cold_who_policy,
   "PHARMA.RECALL.v1"        => pharma_recall_policy,
   "PHARMA.PMDA.v1"          => pharma_pmda_policy,
   "PHARMA.ANVISA.v1"        => pharma_anvisa_policy,
   "PHARMA.MHRA.v1"          => pharma_mhra_policy,
   "FOOD.FSMA.v1"            => food_fsma_policy,
   "FOOD.EU.v1"              => food_eu_policy,
   "FOOD.COLD.v1"            => food_cold_policy,
   "FOOD.ORGANIC.USDA.v1"    => food_organic_policy,
   "FOOD.HALAL.v1"           => food_halal_policy,
   "FOOD.KOSHER.v1"          => food_kosher_policy,
   "FOOD.RECALL.v1"          => food_recall_policy,
   "ELEC.REACH.v1"           => elec_reach_policy,
   "ELEC.ROHS.v1"            => elec_rohs_policy,
   "ELEC.CONFLICT.v1"        => elec_conflict_policy,
   "ELEC.WEEE.v1"            => elec_weee_policy,
   "ELEC.ORIGIN.v1"          => elec_origin_policy,
   "APPAREL.LABOR.v1"        => apparel_labor_policy,
   "APPAREL.ORIGIN.v1"       => apparel_origin_policy,
   "APPAREL.ORGANIC.v1"      => apparel_organic_policy,
   "APPAREL.FAIR.v1"         => apparel_fair_policy,
   "ENERGY.REC.v1"           => energy_rec_policy,
   "ENERGY.CARBON.v1"        => energy_carbon_policy,
   "ENERGY.GRID.v1"          => energy_grid_policy,
   "ENERGY.ISO50001.v1"      => energy_iso50001_policy,
   _                         => open_policy
 }
}

fn min_reputation_for(claim_space) {
 let policy = policy_for(claim_space) in
 let rep_ops = list.filter(policy.rules, fn(r) { r.op == "RepMin" }) in
 if list.len(rep_ops) > 0
 then rec.getOr(list.head(rep_ops), "val", 0)
 else 0
}

fn max_age_for(claim_space) {
 let policy = policy_for(claim_space) in
 let age_ops = list.filter(policy.rules, fn(r) { r.op == "AgeMax" }) in
 if list.len(age_ops) > 0
 then rec.getOr(list.head(age_ops), "seconds", 0)
 else 0
}

fn requires_age_check(claim_space) {
 max_age_for(claim_space) > 0
}

export {
 rep_0, rep_1, rep_5, rep_10, rep_20, rep_50,
 custody_policy, inspection_policy, sensor_policy, recall_policy,
 iso9001_policy, iso28000_policy,
 customs_us_policy, customs_eu_policy, customs_uk_policy,
 customs_cn_policy, customs_jp_policy,
 pharma_fda_dscsa_policy, pharma_ema_fmd_policy,
 pharma_cold_fda_policy, pharma_cold_who_policy,
 pharma_recall_policy, pharma_pmda_policy,
 pharma_anvisa_policy, pharma_mhra_policy,
 food_fsma_policy, food_eu_policy, food_cold_policy,
 food_organic_policy, food_halal_policy, food_kosher_policy,
 food_recall_policy,
 elec_reach_policy, elec_rohs_policy, elec_conflict_policy,
 elec_weee_policy, elec_origin_policy,
 apparel_labor_policy, apparel_origin_policy,
 apparel_organic_policy, apparel_fair_policy,
 energy_rec_policy, energy_carbon_policy,
 energy_grid_policy, energy_iso50001_policy,
 open_policy,
 policy_for, min_reputation_for, max_age_for, requires_age_check
}
