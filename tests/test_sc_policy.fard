// --- Policy router ---

test "policy_for custody returns custody_policy" {
  let p = policy.policy_for(jur.SUPPLY_CUSTODY_V1) in
  list.len(p.rules) == 3
}

test "policy_for cold chain returns pharma_cold_fda_policy" {
  let p = policy.policy_for(jur.PHARMA_COLD_FDA_V1) in
  list.len(p.rules) == 4
}

test "min_reputation_for custody is 0" {
  policy.min_reputation_for(jur.SUPPLY_CUSTODY_V1) == 0
}

test "min_reputation_for recall is 50" {
  policy.min_reputation_for(jur.SUPPLY_RECALL_V1) == 50
}

test "min_reputation_for pharma_fda is 20" {
  policy.min_reputation_for(jur.PHARMA_FDA_DSCSA_V1) == 20
}

test "min_reputation_for cold_fda is 10" {
  policy.min_reputation_for(jur.PHARMA_COLD_FDA_V1) == 10
}

test "max_age_for cold_fda is 3600" {
  policy.max_age_for(jur.PHARMA_COLD_FDA_V1) == 3600
}

test "max_age_for customs_us is 86400" {
  policy.max_age_for(jur.SUPPLY_CUSTOMS_US_V1) == 86400
}

test "max_age_for custody is 0 (no age check)" {
  policy.max_age_for(jur.SUPPLY_CUSTODY_V1) == 0
}

test "requires_age_check true for cold chain" {
  policy.requires_age_check(jur.PHARMA_COLD_FDA_V1) == true
}

test "requires_age_check false for custody" {
  policy.requires_age_check(jur.SUPPLY_CUSTODY_V1) == false
}

test "sensor_policy has AgeMax 300" {
  policy.max_age_for(jur.SUPPLY_SENSOR_V1) == 300
}

test "open_policy passes any known jurisdiction with rep=0" {
  let claim = make_claim(jur.FOOD_HALAL_V1) in
  gate.eval_with_ctx_json(claim, { reputation: 0, now: now, policy: policy.open_policy }).ok == true
}
