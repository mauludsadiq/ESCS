import("std/rec") as rec
import("std/list") as list
import("../src/supply_chain/policy") as policy
import("../src/supply_chain/jurisdictions") as jur
import("/Users/g.bogans/Downloads/EOS/src/kernel/gate") as gate
import("/Users/g.bogans/Downloads/EOS/src/kernel/kernel") as eos

let k = eos.new("escs-policy-test-node")
let now = 1710000000

fn make_claim(claim_space) {
  let env = eos.mint_claim(k, claim_space, "sc:test:batch-001",
    "test_event", "{}", [], now) in
  env.claim
}

fn eval(claim_space, reputation) {
  let claim = make_claim(claim_space) in
  let p = policy.policy_for(claim_space) in
  gate.eval_with_ctx_json(claim, { reputation: reputation, now: now, policy: p })
}

// --- Cross-vertical ---

test "custody_policy passes with rep=0" {
  eval(jur.SUPPLY_CUSTODY_V1, 0).ok == true
}

test "inspection_policy passes with rep=5" {
  eval(jur.SUPPLY_INSPECTION_V1, 5).ok == true
}

test "inspection_policy fails with rep=4" {
  rec.has(eval(jur.SUPPLY_INSPECTION_V1, 4), "err")
}

test "recall_policy passes with rep=50" {
  eval(jur.SUPPLY_RECALL_V1, 50).ok == true
}

test "recall_policy fails with rep=49" {
  rec.has(eval(jur.SUPPLY_RECALL_V1, 49), "err")
}

test "iso9001_policy passes with rep=20" {
  eval(jur.SUPPLY_ISO9001_V1, 20).ok == true
}

test "customs_us_policy passes with rep=10" {
  eval(jur.SUPPLY_CUSTOMS_US_V1, 10).ok == true
}

test "customs_us_policy fails with rep=9" {
  rec.has(eval(jur.SUPPLY_CUSTOMS_US_V1, 9), "err")
}

